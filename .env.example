# Configuración del Agente de Skills (LiteLLM)

# Proveedor y Modelo (ejemplos: gemini/gemini-2.0-flash, groq/llama-3.1-70b-versatile)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
SKILLS_DIR=skills

# API Keys (LiteLLM las usa automáticamente si el nombre es estándar)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# GitLab Configuration
GITLAB_TOKEN=your_gitlab_token_here

# --- SECCIÓN DE EMBEDDINGS (Base de Conocimientos) ---
# Puedes usar un proveedor diferente al de Chat si incluyes el prefijo (ej: openai/, gemini/, ollama/)
QDRANT_URL=:memory:
QDRANT_API_KEY=
# Ejemplos: 
# EMBEDDING_MODEL=gemini/text-embedding-004
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_MODEL=ollama/nomic-embed-text (requiere Ollama corriendo localmente)
#EMBEDDING_MODEL=gemini/text-embedding-004
EMBEDDING_MODEL=ollama/nomic-embed-text
